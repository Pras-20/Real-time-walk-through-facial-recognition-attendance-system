# ─── Azure Face API ───────────────────────────────────────────────────
# From: Azure Portal → Face resource → Keys and Endpoint
FACE_KEY=your_azure_face_api_key_here
FACE_ENDPOINT=https://<resource-name>.cognitiveservices.azure.com/
ACCOUNT_REGION=centralindia

# The Person Group ID you created in Azure Face API (no quotes)
PERSON_GROUP_ID=your-person-group-id

# ─── Azure Blob Storage ───────────────────────────────────────────────
# From: Azure Portal → Storage Account → Access Keys → Connection string
BLOB_CONN_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# Name of the blob container (will be auto-created if missing)
BLOB_CONTAINER=attendance-audits

# ─── Azure SQL Database ───────────────────────────────────────────────
# From: Azure Portal → SQL Database → Connection strings → ODBC (include password)
SQL_CONNECTION_STRING=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<db>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
